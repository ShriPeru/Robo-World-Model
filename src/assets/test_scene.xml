<mujoco model="verification_workspace">
    <compiler coordinate="local" inertiafromgeom="true"/>
    <option gravity="0 0 -9.81"  wind="1 3 0" density="1.225" viscosity="0.0001" timestep="0.002"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.1 0.1" rgb2="0.3 0.3 0.3" width="512" height="512" mark="cross" markrgb="0.8 0.8 0.8"/>
        <material name="grid_floor" texture="grid" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="false"/>

        <geom name="floor" type="plane" size="0 0 0.1" material="grid_floor"/>

        <body name="falling_sphere" pos="0 0 1.5">
            <joint name="falling_sphere_joint" type="free"/>
            <geom type="sphere" size="0.1" rgba="0.8 0.2 0.2 1" mass="1.0"/>
        </body>
    </worldbody>

</mujoco>